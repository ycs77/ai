{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "0",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebSearch",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Bash(echo *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf ./*)",
      "Bash(rm -r *)",
      "Bash(rm -r ./*)",
      "Bash(sudo *)",
      "Bash(cat *env*)",
      "Bash(cat *secret*)",
      "Bash(cat *credential*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(.env.production)",
      "Read(.env.development)",
      "Read(.env.staging)",
      "Read(.env.test)",
      "Read(.env.ci)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.*.local)",
      "Edit(.env.production)",
      "Edit(.env.development)",
      "Edit(.env.staging)",
      "Edit(.env.test)",
      "Edit(.env.ci)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.*.local)",
      "Write(.env.production)",
      "Write(.env.development)",
      "Write(.env.staging)",
      "Write(.env.test)",
      "Write(.env.ci)",
      "Read(secrets/**)",
      "Read(**/*credential*)",
      "Read(**/*secret*)",
      "Read(**/*token*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "autoUpdatesChannel": "stable",
  "autoMemoryEnabled": false,
  "model": "opus",
  "outputStyle": "Iroha",
  "tui": "default"
}
