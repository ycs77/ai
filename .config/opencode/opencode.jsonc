{
  "$schema": "https://opencode.ai/config.json",

  // Models
  "model": "opencode-go/kimi-k2.7-code",
  "small_model": "opencode-go/deepseek-v4-flash",
  "provider": {
    "opencode-go": {
      "whitelist": [
        // S Tier
        "glm-5.2",
        "kimi-k3",
        "qwen3.7-max",

        // A Tier
        "kimi-k2.7-code",
        "glm-5.1",
        "minimax-m3",
        "qwen3.7-plus",

        // C Tier
        "deepseek-v4-flash"
      ]
    }
  },

  // Permissions
  "permission": {
    "read": {
      "*": "allow",
      // .env files
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      // Secrets
      "**/secrets/**": "deny",
      "**/appsettings.json": "deny",
      "**/*credential*": "deny",
      "**/*secret*": "deny",
      "**/*token*": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.crt": "deny"
    },
    "edit": {
      "*": "allow",
      // .env files
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      // Secrets
      "**/secrets/**": "deny",
      "**/appsettings.json": "deny",
      "**/*credential*": "deny",
      "**/*secret*": "deny",
      "**/*token*": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.crt": "deny"
    },
    "bash": {
      "*": "ask",
      // Environment
      "env": "deny",
      "printenv": "deny",
      "cat *env*": "deny",
      // Git
      "git *": "allow",
      "git commit *": "ask",
      "git push *": "ask",
      // Node.js
      "npm *": "allow",
      "yarn *": "allow",
      "pnpm *": "allow",
      // PHP
      "composer *": "allow"
    }
  }
}
