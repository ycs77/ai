{
  "$schema": "https://opencode.ai/config.json",

  // Models
  "model": "opencode-go/kimi-k2.7-code",
  "small_model": "opencode-go/deepseek-v4-flash",
  "provider": {
    "opencode-go": {
      "whitelist": [
        // S Tier
        "glm-5.2",
        "kimi-k3",
        "qwen3.7-max",

        // A Tier
        "kimi-k2.7-code",
        "glm-5.1",
        "minimax-m3",
        "qwen3.7-plus",

        // C Tier
        "deepseek-v4-flash"
      ]
    }
  },

  // Permissions
  "permission": {
    "read": {
      "*": "allow",

      // .env files
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",

      // Secrets
      "**/secrets/**": "deny",
      "**/appsettings.json": "deny",
      "**/*credential*": "deny",
      "**/*secret*": "deny",
      "**/*token*": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.crt": "deny"
    },

    "edit": {
      "*": "allow",

      // .env files
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",

      // Secrets
      "**/secrets/**": "deny",
      "**/appsettings.json": "deny",
      "**/*credential*": "deny",
      "**/*secret*": "deny",
      "**/*token*": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.crt": "deny"
    },

    "bash": {
      "*": "allow",

      // Secrets & environment
      "env": "deny",
      "printenv": "deny",
      "cat *env*": "deny",
      "cat .env.example": "allow",

      // Shell output & file read — route to proper tools
      "echo*": "ask",
      "cat*": "ask",

      // Deletion (all shells)
      "rm -rf /": "deny",
      "rm*": "ask",
      "*rmdir*": "ask",
      "unlink*": "ask",
      "*Remove-Item*": "ask",
      "del*": "ask",
      "erase*": "ask",
      "cmd /c *del*": "ask",
      "cmd /c *erase*": "ask",
      "find * -delete*": "ask",

      // Disk-level destruction
      "format*": "deny",
      "diskpart*": "deny",
      "dd*": "deny",
      "mkfs*": "deny",

      // System power
      "shutdown*": "deny",
      "reboot*": "deny",
      "halt*": "deny",

      // Registry
      "reg delete*": "deny",

      // Process kill (unsaved state loss)
      "taskkill*": "ask",
      "kill*": "ask",

      // File overwrite / remote transfer
      "mv -f*": "ask",
      "mv --force*": "ask",
      "scp*": "ask",
      "rsync*": "ask",
      "ssh*": "ask",

      // System ownership / permissions
      "icacls*": "ask",
      "takeown*": "ask",
      "chmod*": "ask",
      "chown*": "ask",

      // Git: destructive / external
      "git commit *": "ask",
      "git push *": "ask",
      "git push --force*": "ask",
      "git push -f *": "ask",
      "git reset --hard*": "ask",
      "git clean*": "ask",
      "git rebase*": "ask",
      "git checkout -- *": "ask",
      "git checkout .": "ask",
      "git stash drop*": "ask",
      "git branch -D*": "ask",

      // Package install / remove (supply-chain risk)
      "npm install*": "ask",
      "npm i *": "ask",
      "npm ci*": "ask",
      "npm uninstall*": "ask",
      "npm rm *": "ask",
      "yarn": "ask",
      "yarn install*": "ask",
      "yarn add*": "ask",
      "pnpm install*": "ask",
      "pnpm i *": "ask",
      "pnpm uninstall*": "ask",
      "pip install*": "ask",
      "pip3 install*": "ask",
      "uv add*": "ask",
      "uv pip install*": "ask",
      "composer require*": "ask",
      "composer install*": "ask",
      "composer update*": "ask",

      // Publish (irreversible public release)
      "npm publish*": "deny",
      "yarn publish*": "deny",
      "pnpm publish*": "deny",

      // Pipe-to-shell remote execution
      "curl *|*sh*": "ask",
      "curl *|*bash*": "ask",
      "wget *|*sh*": "ask",
      "wget *|*bash*": "ask",

      // Docker: data loss
      "docker system prune*": "ask",
      "docker volume rm*": "ask",
      "docker rmi*": "ask",
      "docker rm*": "ask"
    }
  }
}
